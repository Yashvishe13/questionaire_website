# Vercel: Project Settings → Environment Variables (Production / Preview / Development).
# Never commit real keys. Use the service role key only on the server (this API route).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: lock CORS to your Vercel domain instead of "*"
# ALLOW_ORIGIN=https://your-app.vercel.app
